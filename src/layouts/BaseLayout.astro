---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  image?: string; // Optional prop for future thumbnail images
}

const { 
  title, 
  description = 'Modern Java features and usage — practical patterns for enterprise distributed systems and agentic AI.',
  image = '/favicon.svg' // Fallback image for social sharing
} = Astro.props;

// Safely construct the base and canonical URLs
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const canonicalURL = new URL(Astro.url.pathname, Astro.site || Astro.url);
---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
    
    <link rel="canonical" href={canonicalURL} />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(image, canonicalURL)} />

    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonicalURL} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={new URL(image, canonicalURL)} />
  </head>
  <body>
    <header class="site-header">
      <div class="wrap">
        <a class="brand" href={`${base}/`}>
          <span class="dot">&#9656;</span> Modern Java Features and Usage
        </a>
        <nav class="site-nav">
          <a href={`${base}/`}>All posts</a>
          <a href={`${base}/?track=java`}>Java</a>
          <a href={`${base}/?track=enterprise`}>Enterprise</a>
          <a href={`${base}/?track=agentic-ai`}>Agentic AI</a>
        </nav>
      </div>
    </header>
    <main class="wrap">
      <slot />
    </main>
  </body>
</html>