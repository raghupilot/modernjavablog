---
import BaseLayout from './BaseLayout.astro';
import TagChip from '../components/TagChip.astro';

interface Props {
  title: string;
  description: string;
  track: string;
  jdkVersion?: string;
  featureStatus?: 'preview' | 'incubating' | 'stable' | 'final';
  difficulty: string;
  publishDate: Date;
  tags?: string[];
  headings: { depth: number; slug: string; text: string }[];
}

const { title, description, track, jdkVersion, featureStatus, difficulty, publishDate, tags = [], headings } = Astro.props;

// Filter for only H2 and H3 for TOC
const toc = headings.filter(h => h.depth === 2 || h.depth === 3);

const trackLabels: Record<string, string> = {
  java: 'Modern Java',
  enterprise: 'Enterprise Patterns',
  'agentic-ai': 'Agentic AI',
};

const dateStr = publishDate.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<BaseLayout title={`${title} — Modern Java`} description={description}>
  <div class="post-grid">
    <article>
      <header class="article-header">
        <span class="track-label">{trackLabels[track] ?? track}</span>
        <h1>{title}</h1>
        <p class="post-desc">{description}</p>
        
        <div class="article-meta">
          {jdkVersion && <TagChip label={`JDK ${jdkVersion}`} status={featureStatus} />}
          <TagChip label={difficulty} />
          <time class="track-label" datetime={publishDate.toISOString()}>
            {dateStr}
          </time>
        </div>
      </header>
      
      <div class="article-body">
        <slot />
      </div>

      {tags.length > 0 && (
        <footer class="article-tags">
          <h3>Explore Related Topics</h3>
          <div class="tags-container">
            {tags.map((tag) => (
              <a href={`${base}/tags/${tag}/`} class="tag-chip">#{tag}</a>
            ))}
          </div>
        </footer>
      )}
    </article>

    {toc.length >= 3 && (
      <nav class="toc-sidebar">
        <h4>On this page</h4>
        <ul>
          {toc.map((heading) => (
            <li class={`depth-${heading.depth}`}>
              <a href={`#${heading.slug}`}>{heading.text}</a>
            </li>
          ))}
        </ul>
      </nav>
    )}
  </div>
</BaseLayout>

<style>
  .post-grid { display: grid; grid-template-columns: 1fr; gap: 4rem; }
  
  @media (min-width: 1024px) {
    .post-grid { grid-template-columns: 1fr 240px; }
    .toc-sidebar { position: sticky; top: 2rem; height: fit-content; }
  }

  .toc-sidebar h4 { font-size: 0.75rem; color: var(--text-muted); margin-bottom: 1rem; }
  .toc-sidebar ul { list-style: none; padding: 0; margin: 0; }
  .toc-sidebar li { margin-bottom: 0.8rem; line-height: 1.4; }
  .toc-sidebar li.depth-3 { margin-left: 0.75rem; }
  .toc-sidebar a { font-size: 0.9rem; color: var(--text-secondary); }
  .toc-sidebar a:hover { color: var(--amber); }

  .article-tags { margin-top: 3rem; padding-top: 1.5rem; border-top: 1px solid var(--border); }
  .article-tags h3 { font-size: 1rem; color: var(--text-secondary); margin-bottom: 1rem; }
  .tags-container { display: flex; gap: 0.5rem; flex-wrap: wrap; }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const codeBlocks = document.querySelectorAll('pre');

    codeBlocks.forEach((block) => {
      const button = document.createElement('button');
      button.className = 'copy-code-btn';
      button.setAttribute('aria-label', 'Copy code');
      button.setAttribute('title', 'Copy code');

      const copyIcon = `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" /></svg>`;
      const checkIcon = `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="#35C9B0"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" /></svg>`;

      button.innerHTML = copyIcon;
      block.appendChild(button);

      button.addEventListener('click', async () => {
        const codeText = block.querySelector('code')?.innerText;
        if (!codeText) return;

        try {
          await navigator.clipboard.writeText(codeText);
          button.innerHTML = checkIcon;
          button.style.borderColor = '#35C9B0';
          setTimeout(() => {
            button.innerHTML = copyIcon;
            button.style.borderColor = '';
          }, 2000);
        } catch (err) {
          console.error('Failed to copy code: ', err);
        }
      });
    });
  });
</script>