---
import BaseLayout from './BaseLayout.astro';
import TagChip from '../components/TagChip.astro';

interface Props {
  title: string;
  description: string;
  track: string;
  jdkVersion?: string;
  featureStatus?: 'preview' | 'incubating' | 'stable' | 'final';
  difficulty: string;
  publishDate: Date;
  tags?: string[]; // ADD THIS PROP
}

const { title, description, track, jdkVersion, featureStatus, difficulty, publishDate, tags = [] } = Astro.props;

const trackLabels: Record<string, string> = {
  java: 'Modern Java',
  enterprise: 'Enterprise Patterns',
  'agentic-ai': 'Agentic AI',
};

const dateStr = publishDate.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<BaseLayout title={`${title} — Modern Java`} description={description}>
  <article>
    <header class="article-header">
      <span class="track-label">{trackLabels[track] ?? track}</span>
      <h1>{title}</h1>
      <p class="post-desc">{description}</p>
      
      <div class="article-meta">
        {jdkVersion && <TagChip label={`JDK ${jdkVersion}`} status={featureStatus} />}
        <TagChip label={difficulty} />
        <time class="track-label" datetime={publishDate.toISOString()}>
          {dateStr}
        </time>
      </div>
    </header>
    
    <div class="article-body">
      <slot />
    </div>

    {tags.length > 0 && (
      <footer class="article-tags" style="margin-top: 3rem; padding-top: 1.5rem; border-top: 1px solid #eaeaea;">
        <h3 style="font-size: 1rem; color: #666; margin-bottom: 1rem;">Explore Related Topics</h3>
        <div style="display: flex; gap: 0.5rem; flex-wrap: wrap;">
          {tags.map((tag) => (
            <a href={`${base}/tags/${tag}/`} class="tag-chip" style="background: #f1f5f9; color: #475569; text-decoration: none; padding: 0.25rem 0.75rem; border-radius: 999px; font-size: 0.85rem; font-weight: 500;">
              #{tag}
            </a>
          ))}
        </div>
      </footer>
    )}
  </article>
</BaseLayout>