---
import BaseLayout from '../layouts/BaseLayout.astro';
import TagChip from '../components/TagChip.astro';
import { getCollection } from 'astro:content';

const allPosts = (await getCollection('posts', ({ data }) => !data.draft))
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());

const trackLabels: Record<string, string> = {
  java: 'Modern Java',
  enterprise: 'Enterprise Patterns',
  'agentic-ai': 'Agentic AI',
};
---
<BaseLayout title="Release Notes for Humans">
  <p class="post-desc" style="margin-bottom: 2rem; font-size: 1.05rem;">
    Modern Java features, distributed systems patterns, and agentic AI — explained with the
    architectural context you need to actually use them.
  </p>
  <div class="post-list">
    {allPosts.map((post) => (
      <a class="post-card" href={`${import.meta.env.BASE_URL.replace(/\/$/, '')}/posts/${post.id}/`}>
        <div class="post-meta-row">
          <span class="track-label">{trackLabels[post.data.track] ?? post.data.track}</span>
          {post.data.jdkVersion && <TagChip label={`JDK ${post.data.jdkVersion}`} status={post.data.featureStatus} />}
        </div>
        <h2 class="post-title">{post.data.title}</h2>
        <p class="post-desc">{post.data.description}</p>
      </a>
    ))}
  </div>
</BaseLayout>
