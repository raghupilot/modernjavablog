---
const { type = 'info', title } = Astro.props;

const themes = {
  info: 'bg-blue-50 border-blue-500 text-blue-900',
  warning: 'bg-amber-50 border-amber-500 text-amber-900',
  tip: 'bg-green-50 border-green-500 text-green-900',
  danger: 'bg-red-50 border-red-500 text-red-900',
};

const activeTheme = themes[type] || themes.info;
---
<div class={`my-8 px-6 py-5 border-l-4 rounded-r-lg shadow-sm ${activeTheme} not-prose`}>
  {title && <h4 class="font-bold text-lg mb-2 opacity-90">{title}</h4>}
  <div class="text-sm leading-relaxed opacity-80">
    <slot />
  </div>
</div>